<div class="space-y-8">
  <section class="surface-panel px-6 py-8 sm:px-8">
    <div class="flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
      <div>
        <p class="eyebrow">Detalhes do lancamento</p>
        <h1 class="page-title mt-3"><%= @transaction.category.name %></h1>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="<%= category_badge_classes(@transaction.transaction_type) %>"><%= transaction_type_label(@transaction.transaction_type) %></span>
          <span class="<%= status_badge_classes(@transaction.status) %>"><%= transaction_status_label(@transaction.status) %></span>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= link_to "Editar lancamento", edit_wallet_transaction_path(@wallet, @transaction), class: "btn-primary" %>
        <%= link_to "Voltar para lista", wallet_transactions_path(@wallet), class: "btn-secondary" %>
        <%= button_to "Excluir", wallet_transaction_path(@wallet, @transaction), method: :delete, class: "btn-danger", form_class: "inline-flex", data: { turbo_confirm: "Deseja excluir este lancamento?" } %>
      </div>
    </div>
  </section>

  <section class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
    <div class="surface-panel p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Resumo</p>
      <div class="mt-6 space-y-5">
        <div class="surface-soft p-4">
          <p class="text-sm text-slate-500">Valor</p>
          <p class="mt-2 text-3xl font-semibold <%= amount_text_classes(@transaction.transaction_type) %>">
            <%= signed_brl(@transaction.amount, @transaction.transaction_type) %>
          </p>
        </div>
        <div class="surface-soft p-4">
          <p class="text-sm text-slate-500">Data</p>
          <p class="mt-2 text-lg font-semibold text-slate-950"><%= display_date(@transaction.date) %></p>
        </div>
        <div class="surface-soft p-4">
          <p class="text-sm text-slate-500">Carteira</p>
          <p class="mt-2 text-lg font-semibold text-slate-950"><%= @wallet.name %></p>
        </div>
      </div>
    </div>

    <div class="surface-panel p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Informacoes adicionais</p>
      <div class="mt-6 grid gap-4">
        <div class="surface-soft p-5">
          <p class="text-sm text-slate-500">Descricao</p>
          <p class="mt-3 text-base leading-7 text-slate-700"><%= @transaction.description.presence || "Sem descricao informada para este movimento." %></p>
        </div>
        <div class="surface-soft p-5">
          <p class="text-sm text-slate-500">Status atual</p>
          <p class="mt-3 text-base leading-7 text-slate-700">
            Esse lancamento esta marcado como <span class="font-semibold text-slate-950"><%= transaction_status_label(@transaction.status).downcase %></span>.
          </p>
        </div>
        <div class="surface-soft p-5">
          <p class="text-sm text-slate-500">Consistencia</p>
          <p class="mt-3 text-base leading-7 text-slate-700">
            Categoria e tipo permanecem sincronizados para manter o dashboard e as somas corretas.
          </p>
        </div>
      </div>
    </div>
  </section>
</div>
