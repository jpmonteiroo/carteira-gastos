<div class="space-y-8">
  <section class="surface-panel px-6 py-8 sm:px-8">
    <div class="flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
      <div>
        <p class="eyebrow">Carteira selecionada</p>
        <h1 class="page-title mt-3"><%= @wallet.name %></h1>
        <p class="page-copy mt-4">
          <%= @wallet.description.present? ? @wallet.description : "Adicione uma descricao para registrar a finalidade desta carteira e facilitar a manutencao ao longo do tempo." %>
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= link_to "Novo lancamento", new_wallet_transaction_path(@wallet), class: "btn-primary" %>
        <%= link_to "Editar carteira", edit_wallet_path(@wallet), class: "btn-secondary" %>
        <%= button_to "Excluir carteira", wallet_path(@wallet), method: :delete, class: "btn-danger", form_class: "inline-flex", data: { turbo_confirm: "Deseja realmente excluir esta carteira?" } %>
      </div>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <div class="metric-card">
      <p class="text-sm text-slate-500">Saldo</p>
      <p class="mt-3 text-3xl font-semibold text-slate-950"><%= brl(@balance) %></p>
      <p class="mt-2 text-sm <%= @balance.negative? ? 'text-rose-600' : 'text-emerald-600' %>">
        <%= @balance.negative? ? "Despesa acima da receita" : "Resultado positivo acumulado" %>
      </p>
    </div>
    <div class="metric-card">
      <p class="text-sm text-slate-500">Receitas</p>
      <p class="mt-3 text-3xl font-semibold text-slate-950"><%= brl(@income_total) %></p>
      <p class="mt-2 text-sm text-emerald-600">Entradas registradas nesta carteira</p>
    </div>
    <div class="metric-card">
      <p class="text-sm text-slate-500">Despesas</p>
      <p class="mt-3 text-3xl font-semibold text-slate-950"><%= brl(@expense_total) %></p>
      <p class="mt-2 text-sm text-rose-600">Saidas vinculadas a esta carteira</p>
    </div>
    <div class="metric-card">
      <p class="text-sm text-slate-500">Lancamentos</p>
      <p class="mt-3 text-3xl font-semibold text-slate-950"><%= @transactions.count %></p>
      <p class="mt-2 text-sm text-slate-500">Movimentacoes com historico completo.</p>
    </div>
  </section>

  <section class="surface-panel overflow-hidden">
    <div class="flex flex-col gap-4 border-b border-slate-100 px-6 py-6 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Historico</p>
        <h2 class="mt-2 text-2xl font-semibold text-slate-950">Lancamentos da carteira</h2>
      </div>
      <%= link_to "Ver tela completa", wallet_transactions_path(@wallet), class: "btn-secondary" %>
    </div>

    <% if @transactions.any? %>
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Categoria</th>
              <th>Data</th>
              <th>Status</th>
              <th>Valor</th>
              <th></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @transactions.limit(10).each do |transaction| %>
              <tr class="bg-white/40">
                <td>
                  <div class="space-y-2">
                    <p class="font-semibold text-slate-950"><%= transaction.category.name %></p>
                    <span class="<%= category_badge_classes(transaction.transaction_type) %>"><%= transaction_type_label(transaction.transaction_type) %></span>
                  </div>
                </td>
                <td><%= display_date(transaction.date) %></td>
                <td><span class="<%= status_badge_classes(transaction.status) %>"><%= transaction_status_label(transaction.status) %></span></td>
                <td class="font-semibold <%= amount_text_classes(transaction.transaction_type) %>"><%= signed_brl(transaction.amount, transaction.transaction_type) %></td>
                <td class="text-right">
                  <%= link_to "Abrir", wallet_transaction_path(@wallet, transaction), class: "text-sm font-semibold text-slate-500 hover:text-slate-950" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="p-6">
        <%= render "shared/empty_state",
            title: "Sem lancamentos nesta carteira",
            message: "Cadastre receitas ou despesas para transformar esta carteira em um painel util de acompanhamento.",
            action_label: "Criar lancamento",
            action_path: new_wallet_transaction_path(@wallet),
            accent: "TX" %>
      </div>
    <% end %>
  </section>
</div>
