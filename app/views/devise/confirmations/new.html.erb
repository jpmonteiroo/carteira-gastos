<section class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
  <div class="surface-soft p-8">
    <p class="eyebrow">Confirmacao</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950">Reenviar confirmacao de acesso.</h1>
    <p class="mt-4 text-base leading-7 text-slate-600">
      Informe o e-mail cadastrado para receber novamente as instrucoes de confirmacao da conta.
    </p>
  </div>

  <div class="surface-panel p-8 sm:p-10">
    <div class="mb-8">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Reenviar confirmacao</p>
      <h2 class="mt-3 text-3xl font-semibold text-slate-950">Validar conta</h2>
    </div>

    <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
            class: "form-input" %>
      </div>

      <%= f.submit "Reenviar confirmacao", class: "btn-primary w-full" %>
    <% end %>

    <div class="mt-6">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
