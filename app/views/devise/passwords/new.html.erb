<section class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
  <div class="surface-soft p-8">
    <p class="eyebrow">Recuperacao</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950">Recupere o acesso sem perder o ritmo.</h1>
    <p class="mt-4 text-base leading-7 text-slate-600">
      Informe seu e-mail para receber as instrucoes de redefinicao e voltar rapidamente ao painel.
    </p>
  </div>

  <div class="surface-panel p-8 sm:p-10">
    <div class="mb-8">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Esqueci minha senha</p>
      <h2 class="mt-3 text-3xl font-semibold text-slate-950">Enviar instrucoes</h2>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
      </div>

      <%= f.submit "Enviar instrucoes", class: "btn-primary w-full" %>
    <% end %>

    <div class="mt-6">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
