<% notifications = financial_notifications %>
<% notification_tone = highest_notification_tone(notifications) %>

<div class="relative shrink-0" data-dropdown>
  <button
    type="button"
    class="<%= "#{financial_notification_button_classes(notification_tone)} h-10 w-10 justify-center p-0" %>"
    data-dropdown-toggle
    aria-expanded="false"
    aria-label="Abrir notificacoes financeiras"
  >
    <span class="relative flex h-10 w-10 items-center justify-center rounded-2xl border border-current/10 bg-white/80">
      <i class="fa-solid fa-bell text-base"></i>
      <% if notifications.any? %>
        <span class="<%= financial_notification_counter_classes(notification_tone) %>">
          <%= notifications.count %>
        </span>
      <% end %>
    </span>
  </button>

  <div class="absolute right-0 top-full z-40 mt-3 hidden w-[min(92vw,24rem)] overflow-hidden rounded-[28px] border border-white/80 bg-white/95 shadow-2xl shadow-slate-900/10 backdrop-blur-xl" data-dropdown-menu>
    <div class="border-b border-slate-100 px-5 py-4">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Notificacoes</p>
          <p class="mt-2 text-lg font-semibold text-slate-950">Volume financeiro por tipo</p>
        </div>

        <span class="<%= badge_classes(notification_tone) %>">
          <%= notifications.any? ? notifications.count : 0 %>
        </span>
      </div>

      <% if financial_notifications_context[:wallet].present? %>
        <p class="mt-3 text-sm text-slate-500">
          <%= financial_notifications_context[:wallet].name %> | <%= time_period_label(financial_notifications_context[:period]) %>
        </p>
        <p class="mt-1 text-xs text-slate-400">
          <%= "#{display_date(financial_notifications_context[:date_range].begin)} ate #{display_date(financial_notifications_context[:date_range].end)}" %>
        </p>
      <% end %>
    </div>

    <% if notifications.any? %>
      <div class="space-y-3 px-4 py-4">
        <% notifications.each do |notification| %>
          <article class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
            <div class="flex items-start gap-3">
              <div class="<%= financial_notification_icon_wrapper_classes(notification[:tone]) %>">
                <i class="fa-solid <%= notification[:icon] %>"></i>
              </div>

              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="text-sm font-semibold text-slate-950"><%= notification[:title] %></h3>
                  <% if notification[:ratio_percentage].present? %>
                    <span class="<%= badge_classes(notification[:tone]) %>">
                      <%= "#{notification[:ratio_percentage]}%" %>
                    </span>
                  <% end %>
                </div>

                <p class="mt-2 text-sm text-slate-600"><%= notification[:message] %></p>
                <p class="mt-3 text-xs font-medium text-slate-500">
                  <% if notification[:income_total].zero? %>
                    <%= "#{brl(notification[:expense_total])} em despesas e nenhuma receita registrada." %>
                  <% else %>
                    <%= "#{brl(notification[:expense_total])} em despesas para #{brl(notification[:income_total])} em receitas." %>
                  <% end %>
                </p>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="px-5 py-8 text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-100 text-slate-400">
          <i class="fa-regular fa-bell-slash text-lg"></i>
        </div>
        <p class="mt-4 text-sm font-semibold text-slate-900">Nenhum alerta relevante agora</p>
        <p class="mt-2 text-sm text-slate-500">Quando as despesas passarem das faixas de atencao, elas aparecerao aqui.</p>
      </div>
    <% end %>

    <div class="border-t border-slate-100 px-4 py-4">
      <%= link_to "Abrir metricas", financial_notifications_metrics_path, class: "btn-secondary w-full justify-center" %>
    </div>
  </div>
</div>
