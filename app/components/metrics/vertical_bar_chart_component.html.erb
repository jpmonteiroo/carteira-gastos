<div class="surface-panel p-6">
  <div>
    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Evolucao</p>
    <h2 class="mt-2 text-2xl font-semibold text-slate-950"><%= title %></h2>
    <p class="mt-2 text-sm text-slate-500"><%= subtitle %></p>
  </div>

  <% if items.any? && items.any? { |item| item[:value].to_d.positive? } %>
    <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8">
      <% items.each do |item| %>
        <div class="flex min-h-[11rem] flex-col justify-end gap-3">
          <div class="flex min-h-[8rem] items-end rounded-[24px] bg-slate-100/80 p-2">
            <div class="w-full rounded-[18px] bg-gradient-to-t from-rose-500 via-orange-400 to-amber-300 shadow-sm" style="height: <%= column_height(item[:value]) %>%"></div>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500"><%= item[:label] %></p>
            <p class="mt-1 text-sm font-semibold text-slate-950"><%= item[:meta] %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="mt-6 surface-soft px-5 py-8 text-sm text-slate-500">
      <%= empty_message %>
    </div>
  <% end %>
</div>
