<section class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
  <div class="surface-soft p-8">
    <p class="eyebrow">Acesso</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950">Entre para acompanhar sua operacao financeira.</h1>
    <p class="mt-4 text-base leading-7 text-slate-600">
      Consulte suas carteiras, registre novos movimentos e acompanhe a evolucao do saldo em um painel centralizado.
    </p>
  </div>

  <div class="surface-panel p-8 sm:p-10">
    <div class="mb-8">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Login</p>
      <h2 class="mt-3 text-3xl font-semibold text-slate-950">Bem-vindo de volta</h2>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
      </div>

      <div>
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white/70 px-4 py-3 text-sm text-slate-600">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-slate-950 focus:ring-slate-950/20" %>
          <span>Manter sessao ativa neste dispositivo</span>
        </label>
      <% end %>

      <%= f.submit "Entrar", class: "btn-primary w-full" %>
    <% end %>

    <div class="mt-6">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
