<%
  active_filters = local_assigns.fetch(:active_filters, [])
  title = local_assigns.fetch(:title, "Filtros")
  button_label = local_assigns.fetch(:button_label, "Filtrar")
  clear_path = local_assigns[:clear_path]
%>

<section class="surface-soft p-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400"><%= title %></p>
      <% if active_filters.any? %>
        <div class="mt-3 flex flex-wrap gap-2">
          <% active_filters.each do |filter| %>
            <span class="inline-flex items-center rounded-full border border-teal-200 bg-teal-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-teal-700">
              <%= filter %>
            </span>
          <% end %>
        </div>
      <% else %>
        <p class="mt-3 text-sm text-slate-500">Nenhum filtro aplicado no momento.</p>
      <% end %>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row">
      <button type="button" class="btn-secondary justify-center" data-modal-open="<%= modal_id %>">
        <%= button_label %>
      </button>
      <% if active_filters.any? && clear_path.present? %>
        <%= link_to "Limpar filtros", clear_path, class: "btn-ghost justify-center" %>
      <% end %>
    </div>
  </div>
</section>
