<% if record.errors.any? %>
  <div class="rounded-[24px] border border-rose-200 bg-rose-50/90 p-5 text-rose-700 shadow-sm">
    <h2 class="text-sm font-semibold uppercase tracking-[0.2em]">Ajustes necessarios</h2>
    <p class="mt-2 text-sm text-rose-600">Revise os campos abaixo antes de continuar.</p>

    <ul class="mt-4 space-y-2 text-sm">
      <% record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
