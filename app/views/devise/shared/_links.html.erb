<div class="space-y-3 border-t border-slate-100 pt-6 text-sm text-slate-500">
  <%- if controller_name != "sessions" %>
    <p><%= link_to "Ja tenho conta", new_session_path(resource_name), class: "font-semibold text-slate-700 hover:text-slate-950" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != "registrations" %>
    <p><%= link_to "Criar conta", new_registration_path(resource_name), class: "font-semibold text-slate-700 hover:text-slate-950" %></p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <p><%= link_to "Esqueci minha senha", new_password_path(resource_name), class: "font-semibold text-slate-700 hover:text-slate-950" %></p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <p><%= link_to "Reenviar confirmacao", new_confirmation_path(resource_name), class: "font-semibold text-slate-700 hover:text-slate-950" %></p>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
    <p><%= link_to "Reenviar desbloqueio", new_unlock_path(resource_name), class: "font-semibold text-slate-700 hover:text-slate-950" %></p>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <p>
        <%= button_to "Entrar com #{OmniAuth::Utils.camelize(provider)}",
            omniauth_authorize_path(resource_name, provider),
            data: { turbo: false },
            class: "btn-secondary w-full" %>
      </p>
    <% end %>
  <% end %>
</div>
