<div class="space-y-8">
  <section class="surface-panel px-6 py-8 sm:px-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="eyebrow">Categorias</p>
        <h1 class="page-title mt-3">Classificacao elegante para cada movimento.</h1>
        <p class="page-copy mt-4">
          Mantenha receitas e despesas bem separadas para que os relatarios fiquem claros e a operacao do dia a dia seja mais segura.
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= link_to "Nova categoria", new_category_path, class: "btn-primary" %>
        <%= link_to "Dashboard", dashboard_path, class: "btn-secondary" %>
      </div>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-3">
    <div class="metric-card">
      <p class="text-sm text-slate-500">Total de categorias</p>
      <p class="mt-3 text-3xl font-semibold text-slate-950"><%= @categories_count %></p>
      <p class="mt-2 text-sm text-slate-500">Estrutura disponivel para classificar seus lancamentos.</p>
    </div>
    <div class="metric-card">
      <p class="text-sm text-slate-500">Categorias de receita</p>
      <p class="mt-3 text-3xl font-semibold text-slate-950"><%= @categories.count { |category| category.kind == "income" } %></p>
      <p class="mt-2 text-sm text-emerald-600">Entradas agrupadas de forma consistente.</p>
    </div>
    <div class="metric-card">
      <p class="text-sm text-slate-500">Categorias de despesa</p>
      <p class="mt-3 text-3xl font-semibold text-slate-950"><%= @categories.count { |category| category.kind == "expense" } %></p>
      <p class="mt-2 text-sm text-rose-600">Saidas prontas para leitura detalhada.</p>
    </div>
  </section>

  <%= render "shared/filter_toolbar",
      modal_id: "categories-filters-modal",
      title: "Filtros",
      button_label: "Filtrar categorias",
      active_filters: @active_filters,
      clear_path: categories_path %>

  <%= render "shared/filter_modal",
      modal_id: "categories-filters-modal",
      title: "Filtrar categorias",
      subtitle: "Refine a listagem sem sair da tela atual.",
      form_url: categories_path,
      submit_label: "Aplicar filtros",
      clear_path: categories_path,
      active_filters: @active_filters,
      fields_partial: "categories/filter_fields",
      fields_locals: { selected_kind: @selected_kind } %>

  <% if @categories.any? %>
    <section class="surface-panel overflow-hidden">
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Categoria</th>
              <th>Tipo</th>
              <th>Cor</th>
              <th>Uso</th>
              <th></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @categories.each do |category| %>
              <% usage_count = category.attributes["transactions_count"].to_i %>
              <tr class="bg-white/40">
                <td>
                  <div>
                    <p class="font-semibold text-slate-950"><%= category.name %></p>
                    <p class="mt-1 text-sm text-slate-500">Disponivel para novos lancamentos</p>
                  </div>
                </td>
                <td>
                  <span class="<%= category_badge_classes(category.kind) %>"><%= category_kind_label(category.kind) %></span>
                </td>
                <td>
                  <div class="flex items-center gap-3">
                    <span class="h-5 w-5 rounded-full border border-white shadow-sm" style="background-color: <%= category.color.presence || '#0f766e' %>;"></span>
                    <span class="text-sm text-slate-500"><%= category.color.presence || "#0f766e" %></span>
                  </div>
                </td>
                <td class="font-semibold text-slate-950"><%= usage_count %> lanc.</td>
                <td class="text-right">
                  <div class="flex justify-end gap-3">
                    <%= link_to "Editar", edit_category_path(category), class: "text-sm font-semibold text-slate-500 hover:text-slate-950" %>
                    <%= button_to "Excluir", category_path(category), method: :delete, class: "text-sm font-semibold text-rose-600 hover:text-rose-700", form_class: "inline-flex", data: { turbo_confirm: "Deseja excluir esta categoria?" } %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% else %>
    <%= render "shared/empty_state",
        title: "Nenhuma categoria cadastrada",
        message: "Comece criando categorias de receita e despesa para destravar o cadastro de lancamentos com consistencia.",
        action_label: "Criar categoria",
        action_path: new_category_path,
        accent: "CT" %>
  <% end %>
</div>
