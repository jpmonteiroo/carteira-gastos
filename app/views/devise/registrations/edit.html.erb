<section class="grid gap-6 xl:grid-cols-[1fr_0.48fr]">
  <div class="surface-panel p-8 sm:p-10">
    <div class="mb-8">
      <p class="eyebrow">Minha conta</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950">Atualize seus dados de acesso.</h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">
        Revise e-mail e senha para manter sua conta segura sem perder a fluidez da experiencia.
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="rounded-[24px] border border-amber-200 bg-amber-50/90 p-5 text-sm text-amber-700">
          Aguardando confirmacao para: <span class="font-semibold"><%= resource.unconfirmed_email %></span>
        </div>
      <% end %>

      <div>
        <div class="flex items-center justify-between gap-3">
          <%= f.label :password, "Nova senha", class: "form-label mb-0" %>
          <% if @minimum_password_length %>
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= @minimum_password_length %> caracteres min.</span>
          <% end %>
        </div>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-input mt-2" %>
        <p class="form-hint">Deixe em branco se quiser manter a senha atual.</p>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmacao da nova senha", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
      </div>

      <div>
        <%= f.label :current_password, "Senha atual", class: "form-label" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-input" %>
        <p class="form-hint">Usamos sua senha atual para confirmar alteracoes importantes na conta.</p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row">
        <%= f.submit "Salvar alteracoes", class: "btn-primary" %>
        <%= link_to "Voltar ao dashboard", authenticated_root_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>

  <aside class="surface-soft p-6">
    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Zona sensivel</p>
    <h2 class="mt-3 text-2xl font-semibold text-slate-950">Encerrar conta</h2>
    <p class="mt-4 text-sm leading-6 text-slate-600">
      Se voce nao pretende mais usar a aplicacao, pode remover sua conta e encerrar o acesso.
    </p>
    <div class="mt-6">
      <%= button_to "Excluir minha conta",
          registration_path(resource_name),
          data: { turbo_confirm: "Deseja realmente excluir sua conta?" },
          method: :delete,
          class: "btn-danger w-full" %>
    </div>
  </aside>
</section>
