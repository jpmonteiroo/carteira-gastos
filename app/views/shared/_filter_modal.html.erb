<%
  subtitle = local_assigns[:subtitle]
  form_method = local_assigns.fetch(:form_method, :get)
  hidden_fields = local_assigns.fetch(:hidden_fields, {})
  active_filters = local_assigns.fetch(:active_filters, [])
  fields_locals = local_assigns.fetch(:fields_locals, {})
  clear_path = local_assigns[:clear_path]
  submit_label = local_assigns.fetch(:submit_label, "Aplicar")
%>

<div id="<%= modal_id %>" class="fixed inset-0 z-50 hidden" data-modal>
  <div class="absolute inset-0 bg-slate-950/55 backdrop-blur-sm" data-modal-close></div>

  <div class="relative flex min-h-full items-end justify-center p-4 sm:items-center">
    <div class="w-full max-w-xl overflow-hidden rounded-[28px] border border-white/70 bg-[#f8f3eb] shadow-2xl shadow-slate-950/20" role="dialog" aria-modal="true" aria-labelledby="<%= "#{modal_id}-title" %>">
      <div class="flex items-start justify-between gap-4 border-b border-slate-200/70 px-6 py-5 sm:px-7">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Filtros</p>
          <h2 id="<%= "#{modal_id}-title" %>" class="mt-2 text-2xl font-semibold text-slate-950"><%= title %></h2>
          <% if subtitle.present? %>
            <p class="mt-2 text-sm leading-6 text-slate-500"><%= subtitle %></p>
          <% end %>
        </div>

        <button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 transition hover:border-slate-300 hover:text-slate-950" aria-label="Fechar modal" data-modal-close>
          X
        </button>
      </div>

      <%= form_with url: form_url, method: form_method, local: true, class: "px-6 py-6 sm:px-7" do |f| %>
        <% hidden_fields.each do |key, value| %>
          <%= hidden_field_tag key, value %>
        <% end %>

        <div class="space-y-5">
          <% if active_filters.any? %>
            <div class="rounded-[22px] border border-teal-200 bg-teal-50/80 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-teal-700">Ativos</p>
              <div class="mt-3 flex flex-wrap gap-2">
                <% active_filters.each do |filter| %>
                  <span class="inline-flex items-center rounded-full border border-teal-200 bg-white px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-teal-700">
                    <%= filter %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>

          <%= render fields_partial, f: f, **fields_locals %>
        </div>

        <div class="mt-8 flex flex-col gap-3 border-t border-slate-200/70 pt-5 sm:flex-row sm:justify-end">
          <% if clear_path.present? %>
            <%= link_to "Limpar filtros", clear_path, class: "btn-ghost justify-center" %>
          <% end %>
          <button type="button" class="btn-secondary justify-center" data-modal-close>Cancelar</button>
          <%= f.submit submit_label, class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
