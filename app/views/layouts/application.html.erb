<!DOCTYPE html>
<html>
  <head>
    <title>CarteiraGastos</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="relative isolate overflow-x-hidden">
      <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[34rem] bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.65),transparent_60%)]"></div>

      <header class="sticky top-0 z-30 border-b border-white/70 bg-[#f8f3eb]/80 backdrop-blur-xl">
        <div class="app-shell flex flex-col gap-4 py-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="flex items-center justify-between gap-4">
            <%= link_to root_path, class: "flex items-center gap-3" do %>
              <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-950 text-sm font-semibold uppercase tracking-[0.28em] text-white shadow-lg shadow-slate-900/15">
                CG
              </span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-teal-700">CarteiraGastos</p>
                <p class="text-sm text-slate-500">Painel financeiro pessoal</p>
              </div>
            <% end %>
          </div>

          <% if user_signed_in? %>
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
              <nav class="flex flex-wrap gap-2">
                <%= link_to "Dashboard", dashboard_path, class: nav_link_classes(dashboard_path) %>
                <%= link_to "Carteiras", wallets_path, class: nav_link_classes(wallets_path, match: :prefix) %>
                <%= link_to "Categorias", categories_path, class: nav_link_classes(categories_path, match: :prefix) %>
                <%= link_to "Conta", edit_user_registration_path, class: nav_link_classes(edit_user_registration_path) %>
              </nav>

              <div class="flex items-center gap-3 lg:pl-4">
                <div class="hidden rounded-full border border-white/70 bg-white/70 px-4 py-2 text-sm text-slate-500 sm:block">
                  <span class="font-semibold text-slate-900"><%= current_user.email %></span>
                </div>
                <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "btn-secondary", form_class: "inline-flex" %>
              </div>
            </div>
          <% else %>
            <div class="flex flex-wrap gap-3">
              <%= link_to "Entrar", new_user_session_path, class: "btn-secondary" %>
              <%= link_to "Criar conta", new_user_registration_path, class: "btn-primary" %>
            </div>
          <% end %>
        </div>
      </header>

      <main class="app-shell py-8 sm:py-10">
      <% if notice %>
        <div class="mb-6 rounded-[22px] border border-emerald-200 bg-emerald-50/90 px-5 py-4 text-sm font-medium text-emerald-700 shadow-sm">
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="mb-6 rounded-[22px] border border-rose-200 bg-rose-50/90 px-5 py-4 text-sm font-medium text-rose-700 shadow-sm">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
      </main>
    </div>
  </body>
</html>
